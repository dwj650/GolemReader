# Armature guards configuration — THE BUCKET.
# These are the only stack-specific values; the hooks/scripts are universal and read them.
# Tailoring this file to your project is a KEY SETUP STEP (your AI assistant gathers your
# stack details during project setup and fills these in). Until filled, guards that depend
# on a value are skipped with a notice rather than blocking blindly.

PROJECT_NAME="[FILL during setup]"
MAIN_BRANCH="main"

# Fast automated check the test-gate runs before each commit.
# Set to "NO_AUTOMATED_TESTS" for on-device-only projects (then the gate instead requires
# a recorded validation result — a change to ledgers/testing.md — accompanying code).
# Example (Android/Gradle): "./gradlew testDebugUnitTest"
TEST_CMD="[FILL during setup]"

# Build command (used by CI). Example: "./gradlew assembleDebug"
BUILD_CMD="[FILL during setup]"

# Secret scanner command run against staged changes. The installer can fetch one.
# Example (gitleaks): "gitleaks protect --staged --no-banner --redact"
SECRET_SCAN_CMD="[FILL during setup]"

# Paths that count as "state + registers" for the docs-with-code check (space separated).
STATE_PATHS="state/current-state.md ledgers/ ledgers/testing.md"

# Path prefix that counts as application code for the docs-with-code check.
CODE_PREFIX="src/"
