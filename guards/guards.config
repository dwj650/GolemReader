# Armature guards configuration — the only stack-specific values.
PROJECT_NAME="Golem Reader"
MAIN_BRANCH="main"

# Test-gate command run before each commit.
# "NO_AUTOMATED_TESTS" => no command is run; a code commit must instead update ledgers/testing.md.
# Flip to "./gradlew testDebugUnitTest" once the Android project exists (Step S1).
TEST_CMD="./gradlew testDebugUnitTest"

# Build command (used by CI later, not by the pre-commit hook).
BUILD_CMD="./gradlew assembleDebug"

# Secret scanner. Left unfilled on purpose => skipped with a notice until we install gitleaks before the first code push.
SECRET_SCAN_CMD="[FILL during setup]"

# Paths that count as "state + registers" for the docs-with-code check.
STATE_PATHS="state/current-state.md ledgers/ ledgers/testing.md"
# Path prefix that counts as application code (revisit at S1 to match the Android module layout).
CODE_PREFIX="app/"
